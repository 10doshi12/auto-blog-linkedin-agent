# ──────────────────────────────────────────
# GitHub
# ──────────────────────────────────────────
# Fine-grained PAT with repo read access
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=
GITHUB_USERNAME=

# ──────────────────────────────────────────
# OpenRouter
# ──────────────────────────────────────────
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=auto-blog-agent

# ──────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────
# Found in: Project Settings > API
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ──────────────────────────────────────────
# LinkedIn
# ──────────────────────────────────────────
# Optional. Only needed if you want the agent to auto-publish to LinkedIn.
# Long-lived OAuth token with ugcPosts write access.
LINKEDIN_ACCESS_TOKEN=
# Format: urn:li:person:XXXXXXX
LINKEDIN_PERSON_URN=

# ──────────────────────────────────────────
# Agent behaviour
# ──────────────────────────────────────────
# "development" or "production"
ENVIRONMENT=development
# Set to true to skip all Supabase + LinkedIn writes (LLM still runs)
DRY_RUN=false
